datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model VoiceNote {
  id        String   @id @default(uuid())
  audioUrl  String
  format    String
  duration  Int
  sessionId String?
  playCount Int      @default(0)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([sessionId])
}

model Report {
  id          String   @id @default(uuid())
  voiceNoteId String
  sessionId   String
  reason      String?
  createdAt   DateTime @default(now())

  @@unique([voiceNoteId, sessionId])
  @@index([voiceNoteId])
}
